# Modern CLI defaults.
alias ls='eza --icons=auto'
alias ll='eza -lah --icons=auto --git'
alias la='eza -a --icons=auto'
alias l='eza --icons=auto'
alias lt='eza --tree --level=2 --icons=auto'

# Keep the original commands available while making the modern tools easy to reach.
alias c='bat'
alias f='fd'
alias lg='lazygit'
alias ld='lazydocker'
alias ff='fastfetch'

# Open yazi and jump to the last visited directory on exit.
y() {
    local tmp cwd
    tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
    command yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd < "$tmp" || true
    if [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && [ -d "$cwd" ]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}
